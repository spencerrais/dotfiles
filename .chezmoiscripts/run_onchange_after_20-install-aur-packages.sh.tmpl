{{ if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "arch") -}}
#!/usr/bin/env bash
set -euo pipefail

aur_packages=(
  1password
  brave-bin
)

if ! command -v paru >/dev/null 2>&1; then
  echo "paru is required but not installed."
  exit 1
fi

paru -S --needed "${aur_packages[@]}"
{{ end -}}
